    {
      "parameters": {
        "jsCode": "// Payload-Daten vom ersten Input (Payload vorbereiten)\nconst payloadData = $('Payload vorbereiten für Hochladen in RE Ordner in Zoho').first().json;\nconst fileName = payloadData.fileName;\nconst folderId = payloadData.folderId;\n\n// Access Token vom zweiten Input\nconst accessToken = $('Access Token holen').first().json.access_token;\n\n// PDF Binary vom dritten Input (Rechnung herunterladen)\nconst pdfBinary = $('Rechnung herunterladen').first().binary.data;\n\n// Validierung\nif (!accessToken) {\n  throw new Error('Access Token fehlt!');\n}\n\nif (!pdfBinary) {\n  throw new Error('Kein PDF Binary gefunden! Download fehlgeschlagen?');\n}\n\nif (!fileName || !folderId) {\n  throw new Error('fileName oder folderId fehlt!');\n}\n\nreturn [{\n  json: {\n    folderId: folderId,\n    fileName: fileName,\n    accessToken: accessToken\n  },\n  binary: {\n    file: pdfBinary\n  }\n}];"
      },
