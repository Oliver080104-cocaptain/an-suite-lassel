# Supabase (https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Versandweg für Angebots-/Rechnungsmails: "n8n" (Default) oder "graph".
# n8n   = wie bisher, der bestehende n8n-Flow versendet und legt in Zoho ab.
# graph = die Plattform versendet selbst über Microsoft 365.
# Erst auf "graph" stellen, wenn die MS_GRAPH_*-Werte hinterlegt und getestet sind.
EMAIL_VERSAND_MODUS=n8n

# Die bestehenden n8n-Versand-Flows (nur im Modus "n8n" genutzt).
# Vorbelegt mit den aktuellen Produktions-URLs — normalerweise nichts zu tun.
N8N_WEBHOOK_ANGEBOT_VERSAND=https://n8n.srv1367876.hstgr.cloud/webhook/ab34322b-aed4-4a93-b232-9178bf75ecaf
N8N_WEBHOOK_RECHNUNG_VERSAND=https://n8n.srv1367876.hstgr.cloud/webhook/rechnung-versenden

# E-Mail-Versand via Microsoft Graph (Angebote + Rechnungen) — Modus "graph"
# Azure-Portal → Entra ID → App-Registrierungen → neue App anlegen.
# Anwendungsberechtigungen: Mail.Send UND Mail.ReadWrite (letzteres wird für
# Anhänge > 3 MB gebraucht), danach Administratorzustimmung erteilen.
# Details + PowerShell zum Einschränken auf EIN Postfach: src/lib/graph-mail.ts
MS_GRAPH_TENANT_ID=00000000-0000-0000-0000-000000000000
MS_GRAPH_CLIENT_ID=00000000-0000-0000-0000-000000000000
MS_GRAPH_CLIENT_SECRET=your_client_secret_here
MS_GRAPH_SENDER=office@hoehenarbeiten-lassel.at

# n8n-Flows für die Zoho-WorkDrive-Ablage des PDFs (nur noch Upload, kein
# Mailversand mehr). Leerer Wert = Ablage abgeschaltet, das ist der Default.
#
# ERST SETZEN, NACHDEM der jeweilige n8n-Flow reduziert wurde (siehe n8n/README.md).
# Solange die Mail-Nodes im Flow noch aktiv sind, würde die Plattform die Mail
# über Graph verschicken UND der Flow ein zweites Mal — der Kunde bekäme den
# Beleg doppelt.
# Angebot:  https://n8n.srv1367876.hstgr.cloud/webhook/ab34322b-aed4-4a93-b232-9178bf75ecaf
# Rechnung: URL des reduzierten Rechnungs-Flows (bisher /webhook/rechnung-versenden)
N8N_ZOHO_WEBHOOK_ANGEBOT=
N8N_ZOHO_WEBHOOK_RECHNUNG=

# E-Mail via Resend — aktuell ungenutzt (kein Import im src/-Baum)
RESEND_API_KEY=re_xxxxxxxxxxxx

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_FIRMA_NAME=Lassel GmbH

# PDF via API2PDF (https://api2pdf.com)
API2PDF_KEY=your_api2pdf_key_here

# n8n Self-Hosted
N8N_BASE_URL=https://n8n.srv1367876.hstgr.cloud

# Webhook Security (in n8n als Header x-webhook-secret setzen)
WEBHOOK_SECRET=lassel-secret-2026

# Zoho CRM (optional, für spätere Integration)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORG_ID=

# API v1 + MCP-Server (docs/api-v1.md)
# Tokens erzeugen mit: openssl rand -hex 32
# Ohne gesetztes Token antwortet /api/v1/** und /api/mcp mit 503.
API_TOKEN_READ=
# Lesen UND Entwürfe anlegen. Nur setzen, wenn der Agent Angebote vorschlagen
# können soll. Der Entwurfsraum braucht zusätzlich SUPABASE_SERVICE_ROLE_KEY
# und die Migrationen 023 + 024.
API_TOKEN_WRITE=

# Monitoring (cc-monitoring)
MONITORING_PROJECT_SLUG=lassel
MONITORING_API_KEY=cc_xxxxxxxxxxxxxxxxxxxx
